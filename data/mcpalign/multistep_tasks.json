      "target_count": 20
    },
    "multi_source": {
      "description": "Read file → Query DB → Merge (code) → Write → Email (5 steps)",
      "target_count": 20
    },
    "code_deploy": {
      "description": "Read spec → Execute code → Write output",
      "target_count": 20
    }
  }
